# Veritabanı Ayarları
DB_NAME=devdb
DB_USER=devuser
DB_PASS=changeme
DB_HOST=db
DB_PORT=5432

# Django Genel Ayarlar
SECRET_KEY=django-insecure-template-key-change-me
DEBUG=1
ALLOWED_HOSTS=0.0.0.0,127.0.0.1,localhost

# Google OAuth Ayarları (Opsiyonel)
# Alttaki bilgileri doldurduğunuzda Google Login otomatik aktif olur.
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_SECRET=your-google-client-secret-here